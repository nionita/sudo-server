{
  "_comment": "sudo-server configuration — copy to /etc/sudo-server/config.json",

  "socket_path":  "/run/sudo-server/request.sock",
  "socket_group": "sudo-agents",
  "responses_dir": "/run/sudo-server/responses",

  "log_file":  "/var/log/sudo-server/sudo-server.log",
  "audit_log": "/var/log/sudo-server/audit.log",

  "token_ttl":      300,
  "max_output_len": 3000,
  "poll_timeout":   30,
  "max_pending_requests_per_agent": 5,

  "allowed_run_as": ["root"],

  "_comment_allowlist": [
    "At startup, sudo-server requires at least one command restriction.",
    "Use a non-empty command_allowlist or at least one non-empty agent_allowlist entry.",
    "agent_allowlist overrides command_allowlist for a specific user."
  ],
  "command_allowlist": [
    "apt-get", "apt", "dpkg",
    "systemctl",
    "cp", "mv", "mkdir", "chown", "chmod",
    "cat", "tee", "install",
    "pip3", "pip",
    "npm", "npx",
    "docker", "docker-compose"
  ],

  "agent_allowlist": {
    "_comment": "Per-agent overrides. Remove this comment key before using.",
    "agent_browser": ["apt-get", "apt"],
    "agent_dev":     ["apt-get", "apt", "systemctl", "pip3", "npm"]
  },

  "_comment_telegram": [
    "Prefer setting secrets via /etc/sudo-server/env (EnvironmentFile in systemd)",
    "rather than hardcoding them here.",
    "telegram_bot_token: get from @BotFather on Telegram",
    "telegram_chat_id: destination chat for approval prompts.",
    "  In a private chat, this is usually your personal Telegram user ID.",
    "  In a group or channel, this is the group/channel chat ID (for groups often negative, e.g. -100...).",
    "authorized_telegram_users: non-empty list of numeric Telegram user IDs allowed to approve.",
    "  This is separate from telegram_chat_id and has no environment-variable override.",
    "  In a 1:1 chat, your user ID may appear both here and in SUDO_SERVER_TG_CHAT_ID."
  ],
  "telegram_bot_token": "",
  "telegram_chat_id":   "",
  "authorized_telegram_users": [123456789]
}
