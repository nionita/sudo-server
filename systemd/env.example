# /etc/sudo-server/env
# EnvironmentFile for sudo-server.service
# Copy to /etc/sudo-server/env and set permissions: chmod 600 /etc/sudo-server/env
#
# Get your bot token from @BotFather on Telegram (/newbot)
SUDO_SERVER_TG_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Destination chat ID for approval prompts.
# In a private chat, this is your personal Telegram numeric user ID.
# In a group chat, use the group chat ID instead (often negative, e.g. -100123456789).
# Approver user IDs are configured separately in /etc/sudo-server/config.json via
# authorized_telegram_users and do not have an environment-variable override.
SUDO_SERVER_TG_CHAT_ID=123456789
